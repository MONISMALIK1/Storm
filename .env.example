# ──────────────────────────────────────────────────────────────
#  TOW Intelligence Platform — environment variables
#  Copy to .env and fill in the values before deploying.
#  NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────
# Absolute path keeps the DB stable regardless of working directory.
INTEL_DB_PATH=/opt/storm/intel.db

# ── Auth / Security ────────────────────────────────────────────
# Generate once with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# If this is random (unset), every server restart invalidates all user sessions.
INTEL_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Access token lifetime in minutes (default 240 = 4 hours)
INTEL_TOKEN_TTL_MIN=480

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Set to * only for local development.
INTEL_ALLOWED_ORIGINS=https://intel.theorganicworld.in,https://www.theorganicworld.in

# ── Environment flag ───────────────────────────────────────────
# Set to "production" to disable /docs, /redoc, /openapi.json
INTEL_ENV=production

# ── Anthropic (only needed for the LangGraph agent) ────────────
# ANTHROPIC_API_KEY=sk-ant-...
